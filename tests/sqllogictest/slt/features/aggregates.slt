SET optd.optd_strict_mode = true;

statement ok
SET optd.optd_only = true;

statement ok
CREATE TABLE numbers(id int, grp int, val int, bonus int, note varchar);

statement ok
CREATE TABLE dim(id int, category varchar, enabled int);

statement ok
INSERT INTO numbers VALUES
  (1, 1, 10, 0, 'Alpha'),
  (2, 1, 20, 5, 'alphabet'),
  (3, 2, 15, 5, 'Beta'),
  (4, 2, 30, 10, 'gamma'),
  (5, 3, 8, 0, 'delta');

statement ok
INSERT INTO dim VALUES
  (1, 'odd', 1),
  (2, 'even', 1),
  (3, 'odd', 0),
  (4, 'even', 1),
  (6, 'missing', 1);

query
SELECT count(id), sum(val), min(val), max(val)
FROM numbers;
----
5 83 8 30

query
SELECT grp, count(id), sum(val + bonus)
FROM numbers
GROUP BY grp
ORDER BY grp;
----
1 2 35
2 2 60
3 1 8

query
SELECT grp, bonus, count(id)
FROM numbers
GROUP BY grp, bonus
ORDER BY grp, bonus;
----
1 0 1
1 5 1
2 5 1
2 10 1
3 0 1

query
SELECT d.category, count(n.id), sum(n.val)
FROM numbers n
JOIN dim d ON n.id = d.id
GROUP BY d.category
ORDER BY d.category;
----
even 2 50
odd 2 25

query
SELECT grp, sum(val) AS total
FROM numbers
GROUP BY grp
HAVING sum(val) > 20
ORDER BY grp;
----
1 30
2 45

query
SELECT grp, sum(val) AS total
FROM numbers
GROUP BY grp
ORDER BY total DESC
LIMIT 2;
----
2 45
1 30
