query T
SELECT CASE
  WHEN explain_optimizer_json('SELECT id FROM t WHERE val > 1.0') LIKE '%"passName": "Initial"%'
   AND explain_optimizer_json('SELECT id FROM t WHERE val > 1.0') LIKE '%"query": "SELECT id FROM t WHERE val > 1.0"%'
   AND explain_optimizer_json('SELECT id FROM t WHERE val > 1.0') LIKE '%"passName": "JoinOrdering"%'
   AND explain_optimizer_json('SELECT id FROM t WHERE val > 1.0') LIKE '%"durationMs":%'
   AND explain_optimizer_json('SELECT id FROM t WHERE val > 1.0') LIKE '%"result": "unchanged"%'
   AND explain_optimizer_json('SELECT id FROM t WHERE val > 1.0') LIKE '%"op": "projection"%'
   AND explain_optimizer_json('SELECT id FROM t WHERE val > 1.0') LIKE '%"title": "π Projection"%'
  THEN 'ok'
  ELSE 'bad'
END;
----
ok

query ITT
SELECT step, pass, result
FROM explain_steps('SELECT id FROM t WHERE val > 1.0', 'flat')
ORDER BY step;
----
0	initial	initial
1	SubqueryToJoin	unchanged
2	ExprSimplify	unchanged
3	HolisticUnnesting	unchanged
4	MarkJoinToSemiJoin	unchanged
5	PredicatePushdown	unchanged
6	JoinTreeNormalize	unchanged
7	ProjectionElimination	unchanged
8	JoinOrdering	unchanged

query T
SELECT pass
FROM explain_steps('SELECT l.id FROM t l JOIN t r ON l.id = r.id WHERE r.val > 1.0', 'flat')
WHERE step = 2;
----
ExprSimplify
