# Correlated subquery support (EXISTS, NOT EXISTS, IN, scalar subquery)

statement ok
CREATE TABLE orders (o_id BIGINT, o_custkey BIGINT, o_total DOUBLE);

statement ok
CREATE TABLE shipments (s_id BIGINT, s_custkey BIGINT, s_total DOUBLE);

statement ok
CREATE TABLE customers (c_id BIGINT, c_name VARCHAR);

statement ok
INSERT INTO customers VALUES (1, 'alice'), (2, 'bob'), (3, 'carol');

statement ok
INSERT INTO orders VALUES (1, 1, 100.0), (2, 1, 200.0), (3, 2, 50.0);

statement ok
INSERT INTO shipments VALUES (1, 1, 120.0), (2, 1, 140.0), (3, 2, 60.0);

query I
SELECT c_id FROM customers
WHERE EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id)
ORDER BY c_id;
----
1
2

query I
SELECT c_id FROM customers
WHERE NOT EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id)
ORDER BY c_id;
----
3

query IR
SELECT c_id, (SELECT sum(o_total) FROM orders WHERE o_custkey = c_id) AS total
FROM customers
ORDER BY c_id;
----
1	300
2	50
3	NULL

query T
SELECT result
FROM explain_steps('SELECT c_id FROM customers WHERE EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id) ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
changed

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftSemi"%'
   AND plan LIKE '%"condition": "(o_custkey%'
   AND plan NOT LIKE '%SCALAR_SUBQUERY%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id FROM customers WHERE EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id) ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

query T
SELECT result
FROM explain_steps('SELECT c_id FROM customers WHERE NOT EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id) ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
changed

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftAnti"%'
   AND plan LIKE '%"condition": "(o_custkey%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id FROM customers WHERE NOT EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id) ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

query I
SELECT c_id FROM customers
WHERE c_id IN (SELECT o_custkey FROM orders WHERE o_total > c_id)
ORDER BY c_id;
----
1
2

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftSemi"%'
   AND plan LIKE '%o_total%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id FROM customers WHERE c_id IN (SELECT o_custkey FROM orders WHERE o_total > c_id) ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

query IR
SELECT c_id, (SELECT count(*) FROM orders WHERE o_custkey = c_id) AS order_count
FROM customers
ORDER BY c_id;
----
1	2
2	1
3	0

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftOuter"%'
   AND plan LIKE '%count_star()%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id, (SELECT count(*) FROM orders WHERE o_custkey = c_id) AS order_count FROM customers ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

# COUNT defaults must also be visible in predicates, not only projected values.
# Customer 3 has no matching orders, so the scalar count is 0 and the row
# survives the filter.
query I
SELECT c_id FROM customers
WHERE (SELECT count(*) FROM orders WHERE o_custkey = c_id) = 0
ORDER BY c_id;
----
3

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftOuter"%'
   AND plan LIKE '%coalesce%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id FROM customers WHERE (SELECT count(*) FROM orders WHERE o_custkey = c_id) = 0 ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftOuter"%'
   AND plan LIKE '%sum(o_total%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id, (SELECT sum(o_total) FROM orders WHERE o_custkey = c_id) AS total FROM customers ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

query I
SELECT c_id FROM customers
WHERE EXISTS (
  SELECT 1
  FROM (SELECT o_custkey, o_total FROM orders) wrapped
  WHERE wrapped.o_custkey = c_id AND wrapped.o_total > 75.0
)
ORDER BY c_id;
----
1

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftSemi"%'
   AND plan LIKE '%o_total%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id FROM customers WHERE EXISTS (SELECT 1 FROM (SELECT o_custkey, o_total FROM orders) wrapped WHERE wrapped.o_custkey = c_id AND wrapped.o_total > 75.0) ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

query I
SELECT count(*)
FROM customers
WHERE EXISTS (
  SELECT 1
  FROM (SELECT o_id FROM orders WHERE o_total > 1000.0) high_orders
  CROSS JOIN (SELECT s_custkey FROM shipments) s
  WHERE s.s_custkey = c_id
);
----
0

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%o_total%'
   AND plan LIKE '%1000%'
   AND plan LIKE '%s_custkey%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT count(*) FROM customers WHERE EXISTS (SELECT 1 FROM (SELECT o_id FROM orders WHERE o_total > 1000.0) high_orders CROSS JOIN (SELECT s_custkey FROM shipments) s WHERE s.s_custkey = c_id)', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

# Nested scalar aggregate coverage. The inner grouped aggregate must preserve
# its correlated key through the nested projection, otherwise physical planning
# cannot resolve the final join condition.
query IR
SELECT c_id,
  (SELECT max(o_total)
   FROM orders
   WHERE o_custkey = c_id
     AND o_total > (
       SELECT avg(s_total)
       FROM shipments
       WHERE s_custkey = c_id
     )) AS high_total
FROM customers
ORDER BY c_id;
----
1	200
2	NULL
3	NULL

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%avg(s_total%'
   AND plan LIKE '%max(o_total%'
   AND plan LIKE '%s_custkey%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT c_id, (SELECT max(o_total) FROM orders WHERE o_custkey = c_id AND o_total > (SELECT avg(s_total) FROM shipments WHERE s_custkey = c_id)) AS high_total FROM customers ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
ok

# LIMIT decorrelation is intentionally deferred; the unoptimized correlated
# EXISTS shape is not executable through the optd physical path today.
query T
SELECT result
FROM explain_steps('SELECT c_id FROM customers WHERE EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id ORDER BY o_total LIMIT 1) ORDER BY c_id', 'flat')
WHERE pass = 'HolisticUnnesting';
----
unchanged

# Nullable NOT IN must not become a plain anti join. With a NULL on the RHS,
# rows without an equal match evaluate to UNKNOWN, not TRUE, and must be filtered.
statement ok
CREATE TABLE null_probe_outer (x BIGINT);

statement ok
CREATE TABLE null_probe_inner (y BIGINT);

statement ok
INSERT INTO null_probe_outer VALUES (1), (2), (NULL);

statement ok
INSERT INTO null_probe_inner VALUES (1), (NULL);

query I
SELECT count(*) FROM null_probe_outer
WHERE x NOT IN (SELECT y FROM null_probe_inner);
----
0

query T
SELECT CASE
  WHEN result = 'unchanged'
   AND plan LIKE '%NOT IN%'
   AND plan NOT LIKE '%"join_type": "LeftAnti"%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT x FROM null_probe_outer WHERE x NOT IN (SELECT y FROM null_probe_inner) ORDER BY x', 'flat')
WHERE pass = 'SubqueryToJoin';
----
ok

# Once both NOT IN inputs are provably non-null, the anti join rewrite is safe.
query I
SELECT count(*) FROM null_probe_outer
WHERE 99 NOT IN (SELECT y FROM null_probe_inner WHERE y IS NOT NULL);
----
3

query T
SELECT CASE
  WHEN result = 'changed'
   AND plan LIKE '%"join_type": "LeftAnti"%'
  THEN 'ok'
  ELSE 'bad'
END
FROM explain_steps('SELECT x FROM null_probe_outer WHERE 99 NOT IN (SELECT y FROM null_probe_inner WHERE y IS NOT NULL) ORDER BY x', 'flat')
WHERE pass = 'SubqueryToJoin';
----
ok

# Null-safe equality is represented explicitly so NULL=NULL join bindings work.
query I
SELECT count(*)
FROM null_probe_outer o
JOIN null_probe_inner i
  ON o.x IS NOT DISTINCT FROM i.y;
----
2
