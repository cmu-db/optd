# Correlated subquery support (EXISTS, NOT EXISTS, scalar subquery)

statement ok
CREATE TABLE orders (o_id BIGINT, o_custkey BIGINT, o_total DOUBLE);

statement ok
CREATE TABLE customers (c_id BIGINT, c_name VARCHAR);

statement ok
INSERT INTO customers VALUES (1, 'alice'), (2, 'bob'), (3, 'carol');

statement ok
INSERT INTO orders VALUES (1, 1, 100.0), (2, 1, 200.0), (3, 2, 50.0);

query I
SELECT c_id FROM customers
WHERE EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id)
ORDER BY c_id;
----
1
2

query I
SELECT c_id FROM customers
WHERE NOT EXISTS (SELECT 1 FROM orders WHERE o_custkey = c_id)
ORDER BY c_id;
----
3

query IR
SELECT c_id, (SELECT sum(o_total) FROM orders WHERE o_custkey = c_id) AS total
FROM customers
ORDER BY c_id;
----
1	300
2	50
3	NULL
