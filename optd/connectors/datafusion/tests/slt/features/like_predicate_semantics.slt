# Adapted from DuckDB optimizer tests at bcb0c9c5306ccf1cf5c952ea9027740d2587edc0:
# like_optimizer.test.

statement ok
CREATE TABLE like_predicate_text (id BIGINT, s VARCHAR);

statement ok
INSERT INTO like_predicate_text VALUES
  (1, 'aaa'),
  (2, 'aaab'),
  (3, 'baaa'),
  (4, 'bbb'),
  (5, NULL);

query IT
SELECT id, s
FROM like_predicate_text
WHERE s LIKE 'aaa%'
ORDER BY id;
----
1	aaa
2	aaab

query IT
SELECT id, s
FROM like_predicate_text
WHERE s NOT LIKE '%aaa%'
ORDER BY id;
----
4	bbb
