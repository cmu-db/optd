{
  "nodes": [
    {
      "id": 0,
      "kind": "scan",
      "title": "⊞ customer",
      "columns": [
        "c_custkey(#0)"
      ]
    },
    {
      "id": 1,
      "kind": "scan",
      "title": "⊞ orders",
      "columns": [
        "o_custkey(#1)",
        "o_orderkey(#2)",
        "o_comment(#3)"
      ]
    },
    {
      "id": 2,
      "kind": "join",
      "title": "⟕ LeftOuterJoin",
      "join_type": "LeftOuter",
      "condition": "((c_custkey(#0) = o_custkey(#1)) AND NOT(like(o_comment(#3), \"%express%requests%\")))",
      "outer": 0,
      "inner": 1
    },
    {
      "id": 3,
      "kind": "aggregation",
      "title": "γ Aggregation",
      "keys": "c_custkey(#0)",
      "aggregates": [
        "c_count(#4) := count(o_orderkey(#2))"
      ],
      "input": 2
    },
    {
      "id": 4,
      "kind": "aggregation",
      "title": "γ Aggregation",
      "keys": "c_count(#4)",
      "aggregates": [
        "custdist(#5) := count(c_count(#4))"
      ],
      "input": 3
    },
    {
      "id": 5,
      "kind": "sort",
      "title": "⇞ Sort",
      "keys": [
        "custdist(#5) Desc NullsLast",
        "c_count(#4) Desc NullsLast"
      ],
      "input": 4
    },
    {
      "id": 6,
      "kind": "projection",
      "title": "π Projection",
      "columns": [
        "c_count(#4)",
        "custdist(#5)"
      ],
      "input": 5
    },
    {
      "id": 7,
      "kind": "output",
      "title": "= Output",
      "input": 6
    }
  ]
}
