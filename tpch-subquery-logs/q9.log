{
  "nodes": [
    {
      "id": 0,
      "kind": "scan",
      "title": "⊞ part",
      "columns": [
        "p_partkey(#0)",
        "p_name(#1)"
      ]
    },
    {
      "id": 2,
      "kind": "scan",
      "title": "⊞ lineitem",
      "columns": [
        "l_partkey(#4)",
        "l_suppkey(#5)",
        "l_orderkey(#6)",
        "l_extendedprice(#7)",
        "l_discount(#8)",
        "l_quantity(#9)"
      ]
    },
    {
      "id": 6,
      "kind": "cross_product",
      "title": "× CrossProduct",
      "outer": 0,
      "inner": 2
    },
    {
      "id": 1,
      "kind": "scan",
      "title": "⊞ supplier",
      "columns": [
        "s_suppkey(#2)",
        "s_nationkey(#3)"
      ]
    },
    {
      "id": 7,
      "kind": "cross_product",
      "title": "× CrossProduct",
      "outer": 6,
      "inner": 1
    },
    {
      "id": 3,
      "kind": "scan",
      "title": "⊞ partsupp",
      "columns": [
        "ps_partkey(#10)",
        "ps_suppkey(#11)",
        "ps_supplycost(#12)"
      ]
    },
    {
      "id": 8,
      "kind": "cross_product",
      "title": "× CrossProduct",
      "outer": 7,
      "inner": 3
    },
    {
      "id": 4,
      "kind": "scan",
      "title": "⊞ orders",
      "columns": [
        "o_orderkey(#13)",
        "o_orderdate(#14)"
      ]
    },
    {
      "id": 9,
      "kind": "cross_product",
      "title": "× CrossProduct",
      "outer": 8,
      "inner": 4
    },
    {
      "id": 5,
      "kind": "scan",
      "title": "⊞ nation",
      "columns": [
        "n_nationkey(#15)",
        "n_name(#16)"
      ]
    },
    {
      "id": 10,
      "kind": "cross_product",
      "title": "× CrossProduct",
      "outer": 9,
      "inner": 5
    },
    {
      "id": 11,
      "kind": "selection",
      "title": "σ Selection",
      "predicate": "((p_partkey(#0) = l_partkey(#4)) AND (l_suppkey(#5) = s_suppkey(#2)) AND (l_partkey(#4) = ps_partkey(#10)) AND (ps_suppkey(#11) = l_suppkey(#5)) AND (l_orderkey(#6) = o_orderkey(#13)) AND (s_nationkey(#3) = n_nationkey(#15)) AND like(p_name(#1), \"%moccasin%\"))",
      "input": 10
    },
    {
      "id": 12,
      "kind": "map",
      "title": "χ Map",
      "computations": [
        "nation(#17) := n_name(#16)",
        "o_year(#18) := extract_year(o_orderdate(#14))",
        "amount(#19) := ((l_extendedprice(#7) * (100::Decimal128(15, 2) - l_discount(#8))) - (ps_supplycost(#12) * l_quantity(#9)))"
      ],
      "input": 11
    },
    {
      "id": 13,
      "kind": "aggregation",
      "title": "γ Aggregation",
      "keys": "nation(#17), o_year(#18)",
      "aggregates": [
        "sum_profit(#20) := sum(amount(#19))"
      ],
      "input": 12
    },
    {
      "id": 14,
      "kind": "sort",
      "title": "⇞ Sort",
      "keys": [
        "nation(#17) Asc NullsLast",
        "o_year(#18) Desc NullsLast"
      ],
      "input": 13
    },
    {
      "id": 15,
      "kind": "projection",
      "title": "π Projection",
      "columns": [
        "nation(#17)",
        "o_year(#18)",
        "sum_profit(#20)"
      ],
      "input": 14
    },
    {
      "id": 16,
      "kind": "output",
      "title": "= Output",
      "input": 15
    }
  ]
}
