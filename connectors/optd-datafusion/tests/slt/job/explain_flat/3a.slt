query T
SELECT explain_flat('SELECT MIN(t.title) AS movie_title FROM keyword AS k, movie_info AS mi, movie_keyword AS mk, title AS t WHERE k.keyword  like ''%sequel%'' AND mi.info  IN (''Sweden'', ''Norway'', ''Germany'', ''Denmark'', ''Swedish'', ''Denish'', ''Norwegian'', ''German'') AND t.production_year > 2005 AND t.id = mi.movie_id AND t.id = mk.movie_id AND mk.movie_id = mi.movie_id AND k.id = mk.keyword_id;');
