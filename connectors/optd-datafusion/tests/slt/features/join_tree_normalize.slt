# Join conjuncts should be split independently before join-tree normalization.

statement ok
CREATE TABLE a (a_id BIGINT);

statement ok
CREATE TABLE b (b_id BIGINT);

statement ok
CREATE TABLE c (a_id BIGINT, b_id BIGINT);

query T
SELECT explain_flat('SELECT a.a_id, b.b_id, c.a_id, c.b_id FROM a, b, c WHERE a.a_id = c.a_id AND b.b_id = c.b_id');
