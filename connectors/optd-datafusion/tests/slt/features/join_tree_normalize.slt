# Transient equality edges are preserved for backend join execution.

statement ok
CREATE TABLE ta (x BIGINT);

statement ok
CREATE TABLE tb (x BIGINT);

statement ok
CREATE TABLE tc (x BIGINT);

query T
SELECT explain_flat('SELECT ta.x, tb.x, tc.x FROM ta, tb, tc WHERE ta.x = tb.x AND tb.x = tc.x AND ta.x = tc.x');
