# Basic SQL round-trip tests through optd IR

statement ok
CREATE TABLE t (id INT, name VARCHAR, value DOUBLE);

statement ok
INSERT INTO t VALUES (1, 'alice', 1.5), (2, 'bob', 2.5), (3, 'carol', 3.5);

query I
SELECT id FROM t ORDER BY id;
----
1
2
3

query IT
SELECT id, name FROM t WHERE id > 1 ORDER BY id;
----
2	bob
3	carol

query I
SELECT COUNT(*) FROM t;
----
3

query IR
SELECT id, SUM(value) FROM t GROUP BY id ORDER BY id;
----
1	1.5
2	2.5
3	3.5

query I
SELECT id FROM t ORDER BY id LIMIT 2;
----
1
2
