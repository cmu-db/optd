# Table alias and self-join (Q7/Q8 pattern: same table aliased twice)

statement ok
CREATE TABLE nation (n_id BIGINT, n_name VARCHAR, n_regionkey BIGINT);

statement ok
INSERT INTO nation VALUES (1, 'FRANCE', 1), (2, 'GERMANY', 1), (3, 'JAPAN', 2);

query TT
SELECT n1.n_name, n2.n_name
FROM nation n1 JOIN nation n2
  ON n1.n_regionkey = n2.n_regionkey AND n1.n_id < n2.n_id
ORDER BY n1.n_name, n2.n_name;
----
FRANCE	GERMANY
